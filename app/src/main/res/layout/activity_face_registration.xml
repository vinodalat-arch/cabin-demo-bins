<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/background">

    <!-- ═══════ LEFT PANEL: Camera Preview (flex) ═══════ -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_margin="@dimen/space_lg">

        <ImageView
            android:id="@+id/previewImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface"
            android:scaleType="fitCenter"
            android:contentDescription="Face preview" />

        <!-- Camera status overlay at bottom with gradient scrim -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:orientation="vertical"
            android:background="#99000000"
            android:paddingStart="@dimen/space_md"
            android:paddingEnd="@dimen/space_md"
            android:paddingTop="@dimen/space_sm"
            android:paddingBottom="@dimen/space_sm">

            <TextView
                android:id="@+id/cameraStatusText"
                style="@style/TextMicro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Camera: initializing..."
                android:textColor="@color/text_secondary" />

            <ProgressBar
                android:id="@+id/captureProgress"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:max="3"
                android:progress="0"
                android:visibility="gone"
                android:progressTint="@color/accent"
                android:progressBackgroundTint="@color/surface_elevated" />

        </LinearLayout>
    </FrameLayout>

    <!-- ═══════ RIGHT PANEL: Controls (380dp) ═══════ -->
    <LinearLayout
        android:layout_width="@dimen/right_panel_width"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/surface"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        android:paddingTop="@dimen/space_xl"
        android:paddingBottom="@dimen/space_lg">

        <!-- Title -->
        <TextView
            style="@style/TextTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Face Registration"
            android:letterSpacing="0.05" />

        <!-- Status text -->
        <TextView
            android:id="@+id/statusText"
            style="@style/TextBody"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="Position face in frame"
            android:textColor="@color/text_secondary" />

        <!-- Name input -->
        <EditText
            android:id="@+id/nameInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:background="@drawable/bg_input_field"
            android:hint="Enter name"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_muted"
            android:paddingStart="@dimen/space_lg"
            android:paddingEnd="@dimen/space_lg"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:inputType="textPersonName"
            android:maxLines="1"
            android:imeOptions="actionDone" />

        <!-- Button row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:orientation="horizontal">

            <Button
                android:id="@+id/captureButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/space_sm"
                android:background="@drawable/bg_button_accent"
                android:text="Capture"
                android:textColor="#FFFFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:enabled="false" />

            <Button
                android:id="@+id/saveButton"
                android:layout_width="0dp"
                android:layout_height="@dimen/button_height"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_sm"
                android:background="@drawable/bg_button"
                android:text="Save"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:stateListAnimator="@null"
                android:enabled="false" />

        </LinearLayout>

        <!-- Divider + Registered Faces header -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/space_xl"
            android:background="@color/divider" />

        <TextView
            style="@style/TextCaption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="Registered Faces"
            android:textColor="@color/text_secondary" />

        <!-- Scrollable face list -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="@dimen/space_sm"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/faceListLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />

        </ScrollView>

        <!-- Back button -->
        <Button
            android:id="@+id/backButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:layout_marginTop="@dimen/space_md"
            android:background="@drawable/bg_button"
            android:text="Back"
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
