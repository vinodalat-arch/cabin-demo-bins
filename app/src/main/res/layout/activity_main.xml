<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <!-- ═══════════ Main content layer ═══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ═══════════ Three-zone horizontal body ═══════════ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal">

            <!-- ──── LEFT PANEL: Slim status strip (80dp) ──── -->
            <LinearLayout
                android:id="@+id/leftPanel"
                android:layout_width="@dimen/left_panel_width"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingStart="@dimen/space_sm"
                android:paddingEnd="@dimen/space_sm"
                android:paddingTop="@dimen/space_md"
                android:paddingBottom="@dimen/space_sm"
                android:gravity="center_horizontal">

                <!-- Score arc (hidden when idle) -->
                <FrameLayout
                    android:id="@+id/scoreContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/space_sm">

                    <com.incabin.ScoreArcView
                        android:id="@+id/scoreArc"
                        android:layout_width="@dimen/score_arc_size"
                        android:layout_height="@dimen/score_arc_size"
                        android:layout_gravity="center_horizontal" />
                </FrameLayout>

                <!-- Streak / session (hidden when idle) -->
                <LinearLayout
                    android:id="@+id/scorePanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="@dimen/space_sm">

                    <TextView
                        android:id="@+id/streakText"
                        style="@style/TextMicro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="10sp" />

                    <TextView
                        android:id="@+id/bestStreakText"
                        style="@style/TextMicro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Best 0:00"
                        android:textSize="9sp"
                        android:layout_marginTop="1dp" />

                    <TextView
                        android:id="@+id/sessionTimeText"
                        style="@style/TextMicro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0:00"
                        android:textSize="9sp"
                        android:layout_marginTop="1dp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:id="@+id/leftDivider"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/divider"
                    android:layout_marginBottom="@dimen/space_sm"
                    android:visibility="gone" />

                <!-- Camera status (dot only, tap for tooltip) -->
                <View
                    android:id="@+id/cameraStatusDot"
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:background="@color/danger"
                    android:layout_marginBottom="@dimen/space_sm" />

                <!-- Hidden camera status text (for logic compatibility) -->
                <TextView
                    android:id="@+id/cameraStatusText"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:text="No camera" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Start / Stop button -->
                <Button
                    android:id="@+id/toggleButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:background="@drawable/bg_button_accent"
                    android:text="@string/start_service"
                    android:textSize="11sp"
                    android:textColor="#FFFFFFFF"
                    android:textAllCaps="false"
                    android:stateListAnimator="@null" />
            </LinearLayout>

            <!-- ──── CENTER: Camera preview + AI status overlay ──── -->
            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1">

                <ImageView
                    android:id="@+id/previewImage"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="fitCenter"
                    android:background="@color/surface"
                    android:contentDescription="Camera preview" />

                <!-- ASIMO Companion Hub -->
                <LinearLayout
                    android:id="@+id/asimoContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical"
                    android:gravity="center_horizontal"
                    android:visibility="gone">

                    <!-- Branding text -->
                    <TextView
                        android:id="@+id/asimoBrandingText"
                        style="@style/TextMicro"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/asimo_branding"
                        android:textColor="@color/text_muted"
                        android:letterSpacing="0.15"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <!-- Speech bubble -->
                    <FrameLayout
                        android:id="@+id/asimoBubbleFrame"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="2dp">

                        <TextView
                            android:id="@+id/asimoBubbleText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="@dimen/bubble_max_width"
                            android:background="@drawable/bg_speech_bubble"
                            android:paddingStart="@dimen/bubble_padding_h"
                            android:paddingEnd="@dimen/bubble_padding_h"
                            android:paddingTop="@dimen/bubble_padding_v"
                            android:paddingBottom="@dimen/bubble_padding_v"
                            android:textSize="13sp"
                            android:textColor="@color/text_primary"
                            android:gravity="center"
                            android:text="Smart eyes are ready!" />
                    </FrameLayout>

                    <!-- Bubble tail -->
                    <ImageView
                        android:id="@+id/asimoBubbleTail"
                        android:layout_width="16dp"
                        android:layout_height="8dp"
                        android:src="@drawable/bg_bubble_tail"
                        android:layout_marginBottom="@dimen/space_xs"
                        android:contentDescription="@null" />

                    <!-- Glow ring + robot stacked -->
                    <FrameLayout
                        android:id="@+id/asimoGlowFrame"
                        android:layout_width="@dimen/asimo_glow_size_large"
                        android:layout_height="@dimen/asimo_glow_size_large">

                        <com.incabin.AsimoBgGlowView
                            android:id="@+id/asimoGlowView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent" />

                        <ImageView
                            android:id="@+id/asimoMascot"
                            android:layout_width="@dimen/asimo_size_large"
                            android:layout_height="@dimen/asimo_size_large"
                            android:layout_gravity="center"
                            android:scaleType="fitCenter"
                            android:src="@drawable/asimo_all_clear"
                            android:contentDescription="ASIMO mascot" />
                    </FrameLayout>

                    <!-- Detection label below robot -->
                    <TextView
                        android:id="@+id/asimoDetectionLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_detection_label"
                        android:paddingStart="@dimen/space_md"
                        android:paddingEnd="@dimen/space_md"
                        android:paddingTop="@dimen/space_xs"
                        android:paddingBottom="@dimen/space_xs"
                        android:textSize="13sp"
                        android:textColor="@color/danger"
                        android:letterSpacing="0.08"
                        android:visibility="gone"
                        android:layout_marginTop="@dimen/space_sm" />

                </LinearLayout>

                <!-- Idle branding (visible when not monitoring) -->
                <LinearLayout
                    android:id="@+id/idleOverlay"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@color/surface">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Honda Smart Cabin"
                        style="@style/TextTitle"
                        android:textColor="@color/text_muted" />

                    <TextView
                        android:id="@+id/statusText"
                        style="@style/TextCaption"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tap Start to begin monitoring"
                        android:layout_marginTop="@dimen/space_sm" />
                </LinearLayout>

                <!-- AI status overlay at bottom of preview -->
                <TextView
                    android:id="@+id/aiStatusText"
                    style="@style/TextBody"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_ai_scrim"
                    android:gravity="center"
                    android:paddingTop="@dimen/space_xl"
                    android:paddingBottom="@dimen/space_md"
                    android:paddingStart="@dimen/space_lg"
                    android:paddingEnd="@dimen/space_lg"
                    android:text="Tap Start to begin monitoring"
                    android:textColor="@color/text_secondary"
                    android:visibility="gone" />
            </FrameLayout>

            <!-- ──── RIGHT PANEL: Safety dashboard ──── -->
            <LinearLayout
                android:id="@+id/rightPanel"
                android:layout_width="@dimen/right_panel_width"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:background="@color/surface"
                android:paddingStart="@dimen/space_lg"
                android:paddingEnd="@dimen/space_lg"
                android:paddingTop="@dimen/space_lg"
                android:paddingBottom="@dimen/space_sm"
                android:visibility="gone">

                <!-- Risk pill -->
                <TextView
                    android:id="@+id/riskBanner"
                    style="@style/TextHeadline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_risk_pill"
                    android:paddingStart="@dimen/risk_pill_padding_h"
                    android:paddingEnd="@dimen/risk_pill_padding_h"
                    android:paddingTop="@dimen/risk_pill_padding_v"
                    android:paddingBottom="@dimen/risk_pill_padding_v"
                    android:text="LOW"
                    android:textColor="#FF000000"
                    android:layout_marginBottom="@dimen/space_lg" />

                <!-- Driver name -->
                <TextView
                    android:id="@+id/driverNameText"
                    style="@style/TextTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/accent"
                    android:visibility="gone"
                    android:layout_marginBottom="@dimen/space_md" />

                <!-- Passengers -->
                <TextView
                    android:id="@+id/passengerText"
                    style="@style/TextBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 passengers"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/space_xs" />

                <!-- Distraction timer -->
                <TextView
                    android:id="@+id/distractionText"
                    style="@style/TextBody"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Distraction: 0s"
                    android:textColor="@color/text_secondary"
                    android:layout_marginBottom="@dimen/space_lg" />

                <!-- Detection labels container -->
                <LinearLayout
                    android:id="@+id/detectionsContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="@dimen/space_md" />

                <!-- Spacer -->
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <!-- Ticker: last 3 events -->
                <LinearLayout
                    android:id="@+id/tickerContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/divider"
                        android:layout_marginBottom="@dimen/space_sm" />

                    <TextView
                        android:id="@+id/tickerLine1"
                        style="@style/TextMicro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tickerLine2"
                        style="@style/TextMicro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:ellipsize="end" />

                    <TextView
                        android:id="@+id/tickerLine3"
                        style="@style/TextMicro"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:singleLine="true"
                        android:ellipsize="end" />
                </LinearLayout>

                <!-- Hidden engineering metrics (kept in layout for compatibility) -->
                <TextView
                    android:id="@+id/earText"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/marText"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/yawText"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/pitchText"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone" />
            </LinearLayout>
        </LinearLayout>

        <!-- ═══════════ Footer ═══════════ -->
        <TextView
            style="@style/TextMicro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="KPIT Technologies, India"
            android:gravity="center"
            android:paddingTop="@dimen/space_xs"
            android:paddingBottom="@dimen/space_xs" />
    </LinearLayout>

    <!-- ═══════════ Settings overlay layer (above main content) ═══════════ -->

    <!-- Scrim (covers entire screen, dismisses on tap) -->
    <View
        android:id="@+id/settingsScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80000000"
        android:visibility="gone"
        android:clickable="true" />

    <!-- Settings panel (slides in from left) -->
    <LinearLayout
        android:id="@+id/settingsPanel"
        android:layout_width="@dimen/settings_panel_width"
        android:layout_height="match_parent"
        android:layout_marginStart="@dimen/left_panel_width"
        android:orientation="vertical"
        android:background="@drawable/bg_settings_panel"
        android:paddingStart="@dimen/space_xl"
        android:paddingEnd="@dimen/space_xl"
        android:paddingTop="@dimen/space_lg"
        android:paddingBottom="@dimen/space_lg"
        android:visibility="gone"
        android:elevation="8dp"
        android:clickable="true">

        <!-- Header row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_xl">

            <TextView
                style="@style/TextTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="@color/text_primary" />

            <TextView
                android:id="@+id/settingsCloseBtn"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:gravity="center"
                android:text="\u2715"
                android:textSize="18sp"
                android:textColor="@color/text_secondary"
                android:background="?android:attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <!-- Driver Seat Side -->
        <TextView
            style="@style/TextCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Seat"
            android:layout_marginBottom="@dimen/space_sm" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_segmented_button"
            android:layout_marginBottom="@dimen/space_xl">

            <TextView
                android:id="@+id/seatLeftBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="LEFT"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/seatRightBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="RIGHT"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Language -->
        <TextView
            style="@style/TextCaption"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Language"
            android:layout_marginBottom="@dimen/space_sm" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_segmented_button"
            android:layout_marginBottom="@dimen/space_xl">

            <TextView
                android:id="@+id/langEnBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="EN"
                android:textSize="13sp"
                android:textColor="@color/text_primary" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:background="@color/divider" />

            <TextView
                android:id="@+id/langJaBtn"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:text="JA"
                android:textSize="13sp"
                android:textColor="@color/text_secondary" />
        </LinearLayout>

        <!-- Audio Alerts toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_xl">

            <TextView
                style="@style/TextCaption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Audio Alerts" />

            <Button
                android:id="@+id/audioToggle"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_button"
                android:text="ON"
                android:textSize="12sp"
                android:textColor="@color/text_primary"
                android:textAllCaps="false"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- Camera Preview toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="@dimen/space_xl">

            <TextView
                style="@style/TextCaption"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Camera Preview" />

            <Button
                android:id="@+id/previewToggle"
                android:layout_width="72dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_button"
                android:text="OFF"
                android:textSize="12sp"
                android:textColor="@color/text_secondary"
                android:textAllCaps="false"
                android:stateListAnimator="@null" />
        </LinearLayout>

        <!-- WiFi Camera button -->
        <Button
            android:id="@+id/wifiCamButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:text="WiFi Camera..."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="false"
            android:layout_marginBottom="@dimen/space_md"
            android:stateListAnimator="@null" />

        <!-- Face Registry button -->
        <Button
            android:id="@+id/registerButton"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height"
            android:background="@drawable/bg_button"
            android:text="Manage Faces..."
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:textAllCaps="false"
            android:stateListAnimator="@null" />
    </LinearLayout>

</FrameLayout>
